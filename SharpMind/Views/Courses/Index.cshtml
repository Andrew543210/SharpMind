@model CourseCatalogViewModel
@{
    ViewData["Title"] = "Каталог курсів";
}

<div class="card soft-card mb-4">
    <div class="card-body">
        <h1 class="h3 mb-3">Каталог IT-курсів</h1>
        <form method="get" class="row g-2">
            <div class="col-md-3">
                <input asp-for="Filter.Search" class="form-control" placeholder="Пошук за назвою" />
            </div>
            <div class="col-md-2">
                <select asp-for="Filter.Topic" class="form-select" asp-items="Html.GetEnumSelectList<CourseTopic>()">
                    <option value="">Тема</option>
                </select>
            </div>
            <div class="col-md-2">
                <select asp-for="Filter.Level" class="form-select" asp-items="Html.GetEnumSelectList<CourseLevel>()">
                    <option value="">Рівень</option>
                </select>
            </div>
            <div class="col-md-2">
                <input asp-for="Filter.PriceFrom" class="form-control" placeholder="Ціна від" type="number" min="0" step="100" />
            </div>
            <div class="col-md-2">
                <input asp-for="Filter.PriceTo" class="form-control" placeholder="Ціна до" type="number" min="0" step="100" />
            </div>
            <div class="col-md-2">
                <select asp-for="Filter.SortBy" class="form-select" asp-items="Html.GetEnumSelectList<CourseSortType>()"></select>
            </div>
            <div class="col-md-1 d-flex align-items-center">
                <div class="btn-group" role="group" aria-label="Sort direction">
                    <input class="btn-check" type="radio" name="Filter.SortDescending" id="sortAsc" value="false" checked="@(Model.Filter.SortDescending ? null : "checked")" />
                    <label class="btn btn-outline-mint" for="sortAsc" title="Зростання">↑</label>
                    <input class="btn-check" type="radio" name="Filter.SortDescending" id="sortDesc" value="true" checked="@(Model.Filter.SortDescending ? "checked" : null)" />
                    <label class="btn btn-outline-mint" for="sortDesc" title="Спадання">↓</label>
                </div>
            </div>
            <div class="col-md-12 d-grid">
                <button class="btn btn-mint" type="submit">Застосувати</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3">
    @foreach (var course in Model.Courses)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card course-card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@course.Title</h5>
                    <p class="text-muted small mb-1">@course.Topic | @course.Level.GetDisplayName()</p>
                    <p class="card-text flex-grow-1">@course.Description</p>
                    <p class="small mb-1">Ментор: <strong>@course.MentorName</strong></p>
                    <p class="small mb-2">Популярність: @course.Popularity студентів</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-success-subtle text-success">@course.Price.ToString("0") грн</span>
                        <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-outline-mint btn-sm">Деталі</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

