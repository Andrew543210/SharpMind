@using System.Security.Claims
@model CourseDetailsViewModel
@{
    ViewData["Title"] = Model.Course.Title;
    var isApproved = Model.EnrollmentStatus == EnrollmentStatus.Approved;

    static (bool IsLink, string Text, string Url) ParseMaterial(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return (false, string.Empty, string.Empty);
        }

        var startText = raw.IndexOf('[');
        var endText = raw.IndexOf("](");
        var endUrl = raw.LastIndexOf(')');

        if (startText == 0 && endText > 1 && endUrl > endText + 2)
        {
            var text = raw[1..endText];
            var url = raw[(endText + 2)..endUrl];
            if (url.StartsWith("http://") || url.StartsWith("https://"))
            {
                return (true, text, url);
            }
        }

        return (false, raw, string.Empty);
    }
}

<div class="card soft-card mb-3">
    <div class="card-body">
        <h1 class="h3">@Model.Course.Title</h1>
        <p>@Model.Course.Description</p>
        <p class="text-muted small">Тема: @Model.Course.Topic | Рівень: @Model.Course.Level.GetDisplayName() | Ціна: @Model.Course.Price.ToString("0") грн</p>
        <p class="text-muted small">Ментор: @Model.Course.Mentor?.FirstName @Model.Course.Mentor?.LastName (@Model.Course.Mentor?.Email)</p>

        @if (User.IsInRole(AppRoles.Student))
        {
            if (Model.EnrollmentStatus is null)
            {
                <form asp-action="RequestEnrollment" method="post" id="paymentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@Model.Course.Id" />
                    <button class="btn btn-mint" type="button" id="startPayment">Оплатити та подати заявку</button>
                </form>
            }
            else if (Model.EnrollmentStatus == EnrollmentStatus.Pending)
            {
                <div class="alert alert-warning mb-0">Заявка на курс на розгляді.</div>
            }
            else if (Model.EnrollmentStatus == EnrollmentStatus.Rejected)
            {
                <div class="alert alert-danger mb-0">Заявку відхилено ментором.</div>
            }
        }

        @if (isApproved)
        {
            <div class="mt-3">
                <label class="form-label">Загальний прогрес: @Model.ProgressPercent%</label>
                <div class="progress mint-progress">
                    <div class="progress-bar" role="progressbar" style="width:@Model.ProgressPercent%">@Model.ProgressPercent%</div>
                </div>
            </div>

            @if (Model.RatingSummary is not null)
            {
                <div class="mt-3">
                    <div class="alert alert-light mb-2">Ваш рейтинг: @Model.RatingSummary.Points балів, місце @Model.RatingSummary.Rank з @Model.RatingSummary.TotalStudents</div>
                    <a class="btn btn-outline-mint btn-sm" asp-action="Rating" asp-route-courseId="@Model.Course.Id">Переглянути рейтинг курсу</a>
                </div>
            }

            @if (Model.FinalTest is not null)
            {
                var finalScore = Model.TestScores.TryGetValue(Model.FinalTest.Id, out var score) ? score : (decimal?)null;
                <div class="mt-3">
                    @if (finalScore.HasValue)
                    {
                        <p class="small text-muted mb-2">Фінальний тест: @finalScore.Value%</p>
                    }
                    @if (!finalScore.HasValue || finalScore.Value < 100)
                    {
                        <a class="btn btn-outline-mint btn-sm" asp-action="TakeTest" asp-route-testId="@Model.FinalTest.Id" asp-route-courseId="@Model.Course.Id">
                            @(finalScore.HasValue ? "Перепройти фінальний тест" : "Пройти фінальний тест")
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-success small mb-0">Фінальний тест пройдено на максимум.</div>
                    }
                </div>
            }

            <div class="mt-3">
                @if (Model.CertificateId.HasValue)
                {
                    <a class="btn btn-mint btn-sm" asp-action="Certificate" asp-route-id="@Model.CertificateId.Value">Переглянути сертифікат</a>
                }
                else if (Model.CanGetCertificate)
                {
                    <form asp-action="GetCertificate" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="courseId" value="@Model.Course.Id" />
                        <button class="btn btn-mint btn-sm">Отримати сертифікат</button>
                    </form>
                }
            </div>
        }
    </div>
</div>

@if (isApproved || User.IsInRole(AppRoles.Mentor) || User.IsInRole(AppRoles.Admin))
{
    <div class="accordion" id="moduleAccordion">
        @foreach (var module in Model.Course.Modules.OrderBy(m => m.Order))
        {
            <div class="accordion-item mb-2">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#m-@module.Id">
                        @module.Order. @module.Title
                    </button>
                </h2>
                <div id="m-@module.Id" class="accordion-collapse collapse" data-bs-parent="#moduleAccordion">
                    <div class="accordion-body">
                        <p>@module.Description</p>
                        <h6>Матеріали</h6>
                        <ul>
                            @foreach (var material in module.Materials)
                            {
                                var parsed = ParseMaterial(material.Content);
                                <li>
                                    <strong>@material.Title:</strong>
                                    @if (parsed.IsLink)
                                    {
                                        <a href="@parsed.Url" target="_blank" rel="noopener noreferrer">@parsed.Text</a>
                                    }
                                    else
                                    {
                                        @parsed.Text
                                    }
                                </li>
                            }
                        </ul>

                        @if (module.Test is not null && User.IsInRole(AppRoles.Student) && isApproved)
                        {
                            var moduleScore = Model.TestScores.TryGetValue(module.Test.Id, out var score) ? score : (decimal?)null;
                            if (moduleScore.HasValue)
                            {
                                <p class="small text-muted mb-2">Результат тесту: @moduleScore.Value%</p>
                            }
                            if (!moduleScore.HasValue || moduleScore.Value < 100)
                            {
                                <a class="btn btn-outline-mint btn-sm mb-3" asp-action="TakeTest" asp-route-testId="@module.Test.Id" asp-route-courseId="@Model.Course.Id">
                                    @(moduleScore.HasValue ? "Перепройти тест" : "Пройти тест")
                                </a>
                            }
                            else
                            {
                                <div class="alert alert-success small mb-3">Тест пройдено на максимум.</div>
                            }
                        }

                        @if (module.PracticalTask is not null && User.IsInRole(AppRoles.Student) && isApproved)
                        {
                            var grade = Model.PracticalGrades.TryGetValue(module.PracticalTask.Id, out var g) ? g : null;
                            <h6>Практичне завдання: @module.PracticalTask.Title</h6>
                            <p>@module.PracticalTask.Description</p>
                            if (grade.HasValue)
                            {
                                <p class="small text-muted mb-2">Оцінка: @grade.Value</p>
                            }
                            if (!grade.HasValue || grade.Value < 100)
                            {
                                <form asp-action="SubmitTask" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="TaskId" value="@module.PracticalTask.Id" />
                                    <input type="hidden" name="CourseId" value="@Model.Course.Id" />
                                    <textarea name="AnswerText" class="form-control mb-2" rows="3" placeholder="Ваша відповідь"></textarea>
                                    <button class="btn btn-mint btn-sm">@(grade.HasValue ? "Перездати" : "Надіслати відповідь")</button>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-success small">Завдання виконано на максимум.</div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Оплата курсу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <div id="paymentSpinner" class="spinner-border text-success mb-3" role="status"></div>
                <p id="paymentStatusText" class="mb-0">Обробляємо оплату...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        const payButton = document.getElementById("startPayment");
        if (payButton) {
            payButton.addEventListener("click", () => {
                const modalElement = document.getElementById("paymentModal");
                const modal = new bootstrap.Modal(modalElement);
                const spinner = document.getElementById("paymentSpinner");
                const statusText = document.getElementById("paymentStatusText");
                spinner.classList.remove("d-none");
                statusText.textContent = "Обробляємо оплату...";
                modal.show();
                setTimeout(() => {
                    spinner.classList.add("d-none");
                    statusText.textContent = "Оплата пройшла, чекаємо поки ментор прийме вашу заявку";
                    setTimeout(() => document.getElementById("paymentForm").submit(), 800);
                }, 5000);
            });
        }
    </script>
}

