@model Course
@using SharpMind.Services
@{
    ViewData["Title"] = "Редагування курсу";
    var stats = (CourseStatisticsVm)ViewBag.Statistics;
}

<div class="card soft-card mb-3">
    <div class="card-body">
        <a href="@Url.Action("Courses", "Admin")" class="btn btn-secondary btn-sm mb-3">← Назад до списку курсів</a>
        <h1 class="h4">@Model.Title</h1>
        <p>@Model.Description</p>

        <div class="row mb-3">
            <div class="col-md-6">
                <p><strong>Ментор:</strong> @Model.Mentor?.Email</p>
                <p><strong>Рівень:</strong> @Model.Level</p>
                <p><strong>Ціна:</strong> $@Model.Price</p>
            </div>
            <div class="col-md-6">
                <p>
                    <strong>Статус:</strong>
                    <span class="badge @(Model.IsPublished ? "bg-success" : "bg-warning")">
                        @(Model.IsPublished ? "Опублікований" : "Не опублікований")
                    </span>
                </p>
                <p><strong>Модулів:</strong> @Model.Modules.Count</p>
                <p><strong>Студентів:</strong> @stats.TotalEnrollments</p>
            </div>
        </div>

        <form asp-action="UpdateCourseAdmin" method="post" class="row g-2 mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="courseId" value="@Model.Id" />
            <div class="col-md-5">
                <label class="form-label">Назва курсу</label>
                <input type="text" name="title" class="form-control" value="@Model.Title" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Ціна</label>
                <input type="number" name="price" class="form-control" value="@Model.Price" step="0.01" min="0" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Рівень</label>
                <select name="level" class="form-select" required>
                    <option value="Pochatkovyi" asp-selected='@(Model.Level == CourseLevel.Pochatkovyi)'>Початковий</option>
                    <option value="Serednii" asp-selected='@(Model.Level == CourseLevel.Serednii)'>Середній</option>
                    <option value="Prosunutyi" asp-selected='@(Model.Level == CourseLevel.Prosunutyi)'>Просунутий</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Опис</label>
                <textarea name="description" class="form-control" rows="3" required>@Model.Description</textarea>
            </div>
            <div class="col-12 d-grid">
                <button type="submit" class="btn btn-primary">Зберегти зміни</button>
            </div>
        </form>

        <hr />

        <div class="row g-2 mb-3">
            <div class="col-auto">
                <form asp-action="ToggleCoursePublish" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@Model.Id" />
                    <button type="submit" class="btn btn-@(Model.IsPublished ? "warning" : "success")">
                        @(Model.IsPublished ? "Приховати" : "Опублікувати") курс
                    </button>
                </form>
            </div>
            <div class="col-auto">
                <form asp-action="DeleteCourse" method="post" 
                      onsubmit="return confirm('Ви впевнені, що хочете видалити курс? Це видалить усі дані!')" 
                      style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Видалити курс</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Статистика -->
<div class="card soft-card mb-3">
    <div class="card-body">
        <h5>📊 Статистика</h5>
        <div class="row">
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Переглядів</h6>
                        <h2>@stats.TotalViews</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Студентів</h6>
                        <h2>@stats.TotalEnrollments</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Завершено</h6>
                        <h2 class="text-success">@stats.Completed</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h6 class="text-muted">В процесі</h6>
                        <h2 class="text-info">@stats.InProgress</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-3">
            <p><strong>Коефіцієнт завершення:</strong></p>
            <div class="progress" style="height: 30px;">
                <div class="progress-bar @(stats.CompletionRate >= 70 ? "bg-success" : stats.CompletionRate >= 40 ? "bg-warning" : "bg-danger")" 
                     role="progressbar" 
                     style="width: @(Math.Min(stats.CompletionRate, 100))%">
                    @stats.CompletionRate%
                </div>
            </div>
        </div>
        <div class="mt-3 text-end">
            <a href="@Url.Action("CourseStatistics", "Admin", new { courseId = Model.Id })" class="btn btn-info">Детальна статистика</a>
        </div>
    </div>
</div>

<!-- Додати модуль на певну позицію -->
<div class="card soft-card mb-3">
    <div class="card-body">
        <h5>Додати модуль</h5>
        <form asp-action="AddModuleAtPosition" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="courseId" value="@Model.Id" />
            <div class="col-md-3"><input name="title" class="form-control" placeholder="Назва модуля" required /></div>
            <div class="col-md-4"><input name="description" class="form-control" placeholder="Опис модуля" required /></div>
            <div class="col-md-2"><input type="number" min="1" name="position" class="form-control" placeholder="Позиція (опціонально)" /></div>
            <div class="col-md-3 d-grid"><button class="btn btn-mint">Додати модуль</button></div>
        </form>
    </div>
</div>

<!-- МОДУЛІ -->
@foreach (var module in Model.Modules.OrderBy(m => m.Order))
{
    <div class="card soft-card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h5>@module.Order. @module.Title</h5>
                    <p>@module.Description</p>
                </div>
                <form asp-action="DeleteModule" method="post" onsubmit="return confirm('Видалити модуль і весь його контент?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="moduleId" value="@module.Id" />
                    <input type="hidden" name="courseId" value="@Model.Id" />
                    <button type="submit" class="btn btn-sm btn-danger">Видалити модуль</button>
                </form>
            </div>

            <!-- МАТЕРІАЛИ -->
            <h6 class="mt-4 mb-2">📚 Матеріали</h6>
            @if (module.Materials.Any())
            {
                <div class="list-group mb-3">
                    @foreach (var material in module.Materials)
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@material.Title</strong>
                                    <p class="mb-0 small text-muted">@material.Content</p>
                                </div>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-warning btn-sm" onclick="openCustomModal('editMaterialModal@(material.Id)')">Редагувати</button>
                                    <form asp-action="DeleteMaterial" method="post" style="display:inline;" onsubmit="return confirm('Видалити матеріал?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="materialId" value="@material.Id" />
                                        <input type="hidden" name="courseId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Видалити</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Custom Modal для редагування матеріалу -->
                        <div class="custom-modal" id="editMaterialModal@(material.Id)">
                            <div class="custom-modal-dialog">
                                <div class="custom-modal-header">
                                    <h5>Редагувати матеріал</h5>
                                    <button type="button" class="custom-modal-close-btn" onclick="closeCustomModal('editMaterialModal@(material.Id)')">×</button>
                                </div>
                                <form asp-action="EditMaterial" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="materialId" value="@material.Id" />
                                    <input type="hidden" name="courseId" value="@Model.Id" />
                                    <div class="custom-modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Назва матеріалу</label>
                                            <input type="text" name="title" class="form-control" value="@material.Title" required />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Текст/URL</label>
                                            <textarea name="content" class="form-control" rows="4" required>@material.Content</textarea>
                                        </div>
                                    </div>
                                    <div class="custom-modal-footer">
                                        <button type="button" class="btn btn-secondary" onclick="closeCustomModal('editMaterialModal@(material.Id)')">Скасувати</button>
                                        <button type="submit" class="btn btn-primary">Зберегти</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }

            <form asp-action="AddMaterial" method="post" class="row g-2 mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@Model.Id" />
                <input type="hidden" name="moduleId" value="@module.Id" />
                <div class="col-md-4"><input name="title" class="form-control" placeholder="Назва матеріалу" required /></div>
                <div class="col-md-6"><input name="content" class="form-control" placeholder="Текст/URL" required /></div>
                <div class="col-md-2 d-grid"><button class="btn btn-outline-mint">Додати</button></div>
            </form>

            <!-- ТЕСТ -->
            @if (module.Test is not null)
            {
                <h6 class="mt-4 mb-2">✍️ Тест: @module.Test.Title</h6>
                <p class="small text-muted mb-3">Питань: @module.Test.Questions.Count</p>

                @if (module.Test.Questions.Any())
                {
                    <div class="list-group mb-3">
                        @foreach (var question in module.Test.Questions)
                        {
                            <div class="list-group-item">
                                <div>
                                    <strong>@question.Text</strong>
                                    <div class="small mt-2">
                                        @foreach (var option in question.AnswerOptions)
                                        {
                                            <div class="@(option.IsCorrect ? "text-success fw-bold" : "text-muted")">
                                                @(option.IsCorrect ? "✓" : "○") @option.Text
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="btn-group btn-group-sm mt-2" role="group">
                                    <button type="button" class="btn btn-warning btn-sm" onclick="openCustomModal('editQuestionModal@(question.Id)')">Редагувати</button>
                                    <form asp-action="DeleteQuestion" method="post" style="display:inline;" onsubmit="return confirm('Видалити питання?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="questionId" value="@question.Id" />
                                        <input type="hidden" name="courseId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">Видалити</button>
                                    </form>
                                </div>
                            </div>

                            <!-- Custom Modal для редагування питання -->
                            <div class="custom-modal custom-modal-lg" id="editQuestionModal@(question.Id)">
                                <div class="custom-modal-dialog">
                                    <div class="custom-modal-header">
                                        <h5>Редагувати питання</h5>
                                        <button type="button" class="custom-modal-close-btn" onclick="closeCustomModal('editQuestionModal@(question.Id)')">×</button>
                                    </div>
                                    <form asp-action="EditQuestion" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="questionId" value="@question.Id" />
                                        <input type="hidden" name="courseId" value="@Model.Id" />
                                        <div class="custom-modal-body">
                                            <div class="mb-3">
                                                <label class="form-label">Текст питання</label>
                                                <textarea name="text" class="form-control" rows="3" required>@question.Text</textarea>
                                            </div>
                                            @{
                                                var options = question.AnswerOptions.OrderBy(o => question.AnswerOptions.ToList().IndexOf(o)).ToList();
                                                for (int i = 0; i < options.Count; i++)
                                                {
                                                    <div class="mb-3">
                                                        <label class="form-label">Варіант @(i + 1)</label>
                                                        <input type="text" name="option@(i + 1)" class="form-control" value="@options[i].Text" required />
                                                    </div>
                                                }
                                            }
                                            <div class="mb-3">
                                                <label class="form-label">Номер правильної відповіді</label>
                                                @{
                                                    var correctOptionIndex = question.AnswerOptions.ToList().FindIndex(o => o.IsCorrect) + 1;
                                                }
                                                <select name="correctOption" class="form-select" required>
                                                    @for (int i = 1; i <= options.Count; i++)
                                                    {
                                                        <option value="@i" asp-selected='@(i == correctOptionIndex)'>Варіант @i</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="custom-modal-footer">
                                            <button type="button" class="btn btn-secondary" onclick="closeCustomModal('editQuestionModal@(question.Id)')">Скасувати</button>
                                            <button type="submit" class="btn btn-primary">Зберегти</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }

                <form asp-action="AddQuestion" method="post" class="row g-2 mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@Model.Id" />
                    <input type="hidden" name="testId" value="@module.Test.Id" />
                    <div class="col-12"><input name="text" class="form-control" placeholder="Текст питання" required /></div>
                    <div class="col-md-2.4"><input name="option1" class="form-control" placeholder="Варіант 1" required /></div>
                    <div class="col-md-2.4"><input name="option2" class="form-control" placeholder="Варіант 2" required /></div>
                    <div class="col-md-2.4"><input name="option3" class="form-control" placeholder="Варіант 3" required /></div>
                    <div class="col-md-2.4"><input name="option4" class="form-control" placeholder="Варіант 4" required /></div>
                    <div class="col-md-1.6"><input type="number" min="1" max="4" name="correctOption" class="form-control" placeholder="Правильна" required /></div>
                    <div class="col-12 d-grid"><button class="btn btn-outline-mint btn-sm">Додати питання</button></div>
                </form>
            }

            <!-- ПРАКТИЧНЕ ЗАВДАННЯ -->
            @if (module.PracticalTask is not null)
            {
                <div class="mt-4">
                    <h6>🔨 Практичне завдання</h6>
                    <div class="card bg-light p-3 mb-3">
                        <p><strong>@module.PracticalTask.Title</strong></p>
                        <p>@module.PracticalTask.Description</p>
                    </div>
                    <button type="button" class="btn btn-warning btn-sm" onclick="openCustomModal('editTaskModal@(module.PracticalTask.Id)')">Редагувати завдання</button>

                    <!-- Custom Modal для редагування практичного завдання -->
                    <div class="custom-modal" id="editTaskModal@(module.PracticalTask.Id)">
                        <div class="custom-modal-dialog">
                            <div class="custom-modal-header">
                                <h5>Редагувати практичне завдання</h5>
                                <button type="button" class="custom-modal-close-btn" onclick="closeCustomModal('editTaskModal@(module.PracticalTask.Id)')">×</button>
                            </div>
                            <form asp-action="EditPracticalTask" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="taskId" value="@module.PracticalTask.Id" />
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <div class="custom-modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Назва завдання</label>
                                        <input type="text" name="title" class="form-control" value="@module.PracticalTask.Title" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Опис</label>
                                        <textarea name="description" class="form-control" rows="4" required>@module.PracticalTask.Description</textarea>
                                    </div>
                                </div>
                                <div class="custom-modal-footer">
                                    <button type="button" class="btn btn-secondary" onclick="closeCustomModal('editTaskModal@(module.PracticalTask.Id)')">Скасувати</button>
                                    <button type="submit" class="btn btn-primary">Зберегти</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- ФІНАЛЬНИЙ ТЕСТ -->
<div class="card soft-card mb-3">
    <div class="card-body">
        <h5>🏆 Фінальний тест курсу</h5>
        @{
            var finalTest = Model.Tests.FirstOrDefault(t => t.IsFinal);
        }
        <p class="small text-muted mb-3">
            @if (finalTest is not null)
            {
                <span>Питань: @finalTest.Questions.Count</span>
            }
            else
            {
                <span>Фінальний тест не створено</span>
            }
        </p>

        <form asp-action="EnsureFinalTest" method="post" class="row g-2 mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="courseId" value="@Model.Id" />
            <div class="col-md-8">
                <input name="title" class="form-control" value="@finalTest?.Title" placeholder="Назва фінального тесту" />
            </div>
            <div class="col-md-4 d-grid">
                <button class="btn btn-mint">Створити / оновити</button>
            </div>
        </form>

        @if (finalTest is not null)
        {
            @if (finalTest.Questions.Any())
            {
                <div class="list-group mb-3">
                    @foreach (var question in finalTest.Questions)
                    {
                        <div class="list-group-item">
                            <div>
                                <strong>@question.Text</strong>
                                <div class="small mt-2">
                                    @foreach (var option in question.AnswerOptions)
                                    {
                                        <div class="@(option.IsCorrect ? "text-success fw-bold" : "text-muted")">
                                            @(option.IsCorrect ? "✓" : "○") @option.Text
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm mt-2" role="group">
                                <button type="button" class="btn btn-warning btn-sm" onclick="openCustomModal('editFinalQuestionModal@(question.Id)')">Редагувати</button>
                                <form asp-action="DeleteQuestion" method="post" style="display:inline;" onsubmit="return confirm('Видалити питання?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="questionId" value="@question.Id" />
                                    <input type="hidden" name="courseId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Видалити</button>
                                </form>
                            </div>
                        </div>

                        <!-- Custom Modal для редагування питання фінального тесту -->
                        <div class="custom-modal custom-modal-lg" id="editFinalQuestionModal@(question.Id)">
                            <div class="custom-modal-dialog">
                                <div class="custom-modal-header">
                                    <h5>Редагувати питання</h5>
                                    <button type="button" class="custom-modal-close-btn" onclick="closeCustomModal('editFinalQuestionModal@(question.Id)')">×</button>
                                </div>
                                <form asp-action="EditQuestion" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="questionId" value="@question.Id" />
                                    <input type="hidden" name="courseId" value="@Model.Id" />
                                    <div class="custom-modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Текст питання</label>
                                            <textarea name="text" class="form-control" rows="3" required>@question.Text</textarea>
                                        </div>
                                        @{
                                            var finalOptions = question.AnswerOptions.OrderBy(o => question.AnswerOptions.ToList().IndexOf(o)).ToList();
                                            for (int i = 0; i < finalOptions.Count; i++)
                                            {
                                                <div class="mb-3">
                                                    <label class="form-label">Варіант @(i + 1)</label>
                                                    <input type="text" name="option@(i + 1)" class="form-control" value="@finalOptions[i].Text" required />
                                                </div>
                                            }
                                        }
                                        <div class="mb-3">
                                            <label class="form-label">Номер правильної відповіді</label>
                                            @{
                                                var correctFinalIndex = question.AnswerOptions.ToList().FindIndex(o => o.IsCorrect) + 1;
                                            }
                                            <select name="correctOption" class="form-select" required>
                                                @for (int i = 1; i <= finalOptions.Count; i++)
                                                {
                                                    <option value="@i" asp-selected='@(i == correctFinalIndex)'>Варіант @i</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="custom-modal-footer">
                                        <button type="button" class="btn btn-secondary" onclick="closeCustomModal('editFinalQuestionModal@(question.Id)')">Скасувати</button>
                                        <button type="submit" class="btn btn-primary">Зберегти</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }

            <form asp-action="AddQuestion" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@Model.Id" />
                <input type="hidden" name="testId" value="@finalTest.Id" />
                <div class="col-12"><input name="text" class="form-control" placeholder="Текст питання" required /></div>
                <div class="col-md-2.4"><input name="option1" class="form-control" placeholder="Варіант 1" required /></div>
                <div class="col-md-2.4"><input name="option2" class="form-control" placeholder="Варіант 2" required /></div>
                <div class="col-md-2.4"><input name="option3" class="form-control" placeholder="Варіант 3" required /></div>
                <div class="col-md-2.4"><input name="option4" class="form-control" placeholder="Варіант 4" required /></div>
                <div class="col-md-1.6"><input type="number" min="1" max="4" name="correctOption" class="form-control" placeholder="Правильна" required /></div>
                <div class="col-12 d-grid"><button class="btn btn-outline-mint btn-sm">Додати питання</button></div>
            </form>
        }
    </div>
</div>



