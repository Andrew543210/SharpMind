@model SharpMind.ViewModels.Mentor.CreateCourseViewModel
@{
    ViewData["Title"] = "Створення курсу";
}

<div class="card soft-card">
    <div class="card-body">
        <h1 class="h4 mb-3">Новий курс</h1>
        <form asp-action="CreateCourse" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="col-12">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Topic" class="form-label"></label>
                <select asp-for="Topic" class="form-select" asp-items="Html.GetEnumSelectList<CourseTopic>()"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="Level" class="form-label"></label>
                <select asp-for="Level" class="form-select" asp-items="Html.GetEnumSelectList<CourseLevel>()"></select>
            </div>
            <div class="col-md-4">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
            </div>
            <div class="col-12 form-check mt-3 ms-1">
                <input asp-for="IsPublished" class="form-check-input" />
                <label asp-for="IsPublished" class="form-check-label"></label>
            </div>
            <div class="col-12">
                <button class="btn btn-mint">Створити</button>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}

