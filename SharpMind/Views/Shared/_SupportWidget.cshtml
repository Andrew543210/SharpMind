@if (User.IsInRole("Student") || User.IsInRole("Mentor"))
{
    <style>
        .support-widget-button {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #06a77d 0%, #048857 100%);
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(6, 168, 125, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            z-index: 999;
        }

        .support-widget-button:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 16px rgba(6, 168, 125, 0.5);
        }

        .support-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.4);
        }

        .support-modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .support-modal-content {
            background-color: #fefefe;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
        }

        .support-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 1px solid #e0e0e0;
            padding-bottom: 15px;
        }

        .support-modal-header h2 {
            margin: 0;
            font-size: 1.5rem;
            color: #333;
        }

        .support-modal-close {
            font-size: 28px;
            font-weight: bold;
            color: #aaa;
            cursor: pointer;
            border: none;
            background: none;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .support-modal-close:hover,
        .support-modal-close:focus {
            color: #000;
        }

        .support-form-group {
            margin-bottom: 15px;
        }

        .support-form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 500;
            color: #333;
        }

        .support-form-group input,
        .support-form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-family: inherit;
            font-size: 14px;
        }

        .support-form-group input:focus,
        .support-form-group textarea:focus {
            outline: none;
            border-color: #06a77d;
            box-shadow: 0 0 5px rgba(6, 168, 125, 0.3);
        }

        .support-form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .support-submit-btn {
            background: linear-gradient(135deg, #06a77d 0%, #048857 100%);
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s ease;
            width: 100%;
        }

        .support-submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(6, 168, 125, 0.3);
        }

        .support-submit-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }
    </style>

    <button class="support-widget-button" onclick="openSupportModal()" title="Технічна підтримка">
        ❓
    </button>

    <div id="supportModal" class="support-modal">
        <div class="support-modal-content">
            <div class="support-modal-header">
                <h2>Технічна підтримка</h2>
                <button class="support-modal-close" onclick="closeSupportModal()">&times;</button>
            </div>
            <form id="supportForm" asp-controller="Support" asp-action="Ask" method="post">
                @Html.AntiForgeryToken()
                <div class="support-form-group">
                    <label for="subject">Тема питання</label>
                    <input type="text" id="subject" name="Subject" placeholder="Коротко опишіть проблему" required>
                </div>
                <div class="support-form-group">
                    <label for="message">Повідомлення</label>
                    <textarea id="message" name="Message" placeholder="Розкажіть докладніше про вашу проблему..." required></textarea>
                </div>
                <button type="submit" class="support-submit-btn" id="submitBtn">Надіслати питання</button>
            </form>
        </div>
    </div>

    <script>
        function openSupportModal() {
            document.getElementById('supportModal').classList.add('show');
        }

        function closeSupportModal() {
            document.getElementById('supportModal').classList.remove('show');
        }

        // Close modal when clicking outside of it
        window.onclick = function(event) {
            let modal = document.getElementById('supportModal');
            if (event.target == modal) {
                closeSupportModal();
            }
        }

        // Handle form submission with AJAX
        document.getElementById('supportForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = this;
            const submitBtn = document.getElementById('submitBtn');
            
            try {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Надсилання...';
                
                const formData = new FormData(form);
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    // Show success message and clear form
                    form.reset();
                    alert('Ваше питання було надіслано адміністратору. Спасибі!');
                    closeSupportModal();
                } else {
                    alert('Помилка при надсиланні питання. Спробуйте ще раз.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Помилка при надсиланні питання.');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Надіслати питання';
            }
        });
    </script>
}


