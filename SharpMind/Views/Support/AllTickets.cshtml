@model SharpMind.ViewModels.Support.AdminSupportViewModel
@{
    ViewData["Title"] = "Управління питаннями";
}

<div class="container mt-4">
    <h1 class="h2 mb-4">Питання teknічної підтримки</h1>

    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">
                На розгляді (@Model.Pending.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="resolved-tab" data-bs-toggle="tab" data-bs-target="#resolved" type="button" role="tab">
                Вирішено (@Model.Resolved.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="pending" role="tabpanel" aria-labelledby="pending-tab">
            @if (!Model.Pending.Any())
            {
                <div class="alert alert-info">Немає питань на розгляді.</div>
            }
            else
            {
                @foreach (var ticket in Model.Pending)
                {
                    <div class="card soft-card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">@ticket.Subject</h5>
                            <p class="small text-muted">
                                Студент: <strong>@ticket.Student?.Email</strong> | 
                                @ticket.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </p>
                            <p class="card-text">@ticket.Message</p>

                            <form asp-action="RespondTicket" method="post" class="mt-3">
                                <input type="hidden" name="ticketId" value="@ticket.Id" />
                                <div class="mb-3">
                                    <label class="form-label">Ваша відповідь</label>
                                    <textarea name="response" rows="3" class="form-control" placeholder="Напишіть відповідь студенту..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-mint btn-sm">Надіслати відповідь</button>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="tab-pane fade" id="resolved" role="tabpanel" aria-labelledby="resolved-tab">
            @if (!Model.Resolved.Any())
            {
                <div class="alert alert-info">Немає вирішених питань.</div>
            }
            else
            {
                @foreach (var ticket in Model.Resolved)
                {
                    <div class="card soft-card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">@ticket.Subject</h5>
                            <p class="small text-muted">
                                Студент: <strong>@ticket.Student?.Email</strong> | 
                                @ticket.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </p>
                            <p class="card-text"><strong>Питання:</strong> @ticket.Message</p>

                            @if (!string.IsNullOrEmpty(ticket.AdminResponse))
                            {
                                <div class="alert alert-success mt-3">
                                    <strong>Ваша відповідь:</strong>
                                    <p class="mb-0 mt-2">@ticket.AdminResponse</p>
                                    <small class="text-muted">@ticket.ResponseAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

