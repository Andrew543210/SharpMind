@model List<SharpMind.Models.SupportTicket>
@{
    ViewData["Title"] = "Мої питання до підтримки";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2">Мої питання</h1>
                <a asp-action="Ask" class="btn btn-mint">+ Нове питання</a>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    Ви ще не надсилали питань. <a asp-action="Ask">Надішліть своє перше питання</a>.
                </div>
            }
            else
            {
                @foreach (var ticket in Model)
                {
                    <div class="card soft-card mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title">@ticket.Subject</h5>
                                @if (ticket.IsResolved)
                                {
                                    <span class="badge bg-success-subtle">Вирішено</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning" style="background-color: #ffc107; color: #000;">На розгляді</span>
                                }
                            </div>
                            <p class="small text-muted">@ticket.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                            <p class="card-text">@ticket.Message</p>

                            @if (!string.IsNullOrEmpty(ticket.AdminResponse))
                            {
                                <div class="alert alert-info mt-3">
                                    <strong>Відповідь адміністратора:</strong>
                                    <p class="mb-0 mt-2">@ticket.AdminResponse</p>
                                    <small class="text-muted">@ticket.ResponseAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

